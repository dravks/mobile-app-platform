generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubmissionStatus {
  NEW
  REVIEWED
  CLOSED
}

enum Locale {
  tr
  en
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id                  String        @id @default(cuid())
  slug                String        @unique
  nameTr              String
  nameEn              String
  shortDescriptionTr  String
  shortDescriptionEn  String
  fullDescriptionTr   String        @db.Text
  fullDescriptionEn   String        @db.Text
  logoUrl             String?
  coverImageUrl       String?
  category            String
  status              ProjectStatus @default(DRAFT)
  featured            Boolean       @default(false)
  playStoreUrl        String?
  appStoreUrl         String?
  websiteUrl          String?
  supportEmail        String?
  privacyPolicyTr     String        @db.Text
  privacyPolicyEn     String        @db.Text
  termsTr             String        @db.Text
  termsEn             String        @db.Text
  accountDeletionTr   String        @db.Text
  accountDeletionEn   String        @db.Text
  supportContentTr    String        @db.Text
  supportContentEn    String        @db.Text
  faqEnabled          Boolean       @default(true)
  supportEnabled      Boolean       @default(true)
  suggestionsEnabled  Boolean       @default(true)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  images              ProjectImage[]
  faqs                ProjectFaq[]
  suggestions         Suggestion[]
  supportMessages     SupportMessage[]

  @@index([status, featured])
  @@index([category])
}

model ProjectImage {
  id        String   @id @default(cuid())
  projectId String
  url       String
  altTr     String
  altEn     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

model ProjectFaq {
  id        String   @id @default(cuid())
  projectId String
  questionTr String
  questionEn String
  answerTr   String @db.Text
  answerEn   String @db.Text
  sortOrder  Int    @default(0)
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, sortOrder])
}

model Suggestion {
  id        String           @id @default(cuid())
  projectId String?
  name      String?
  email     String?
  message   String           @db.Text
  locale    Locale
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([projectId])
}

model SupportMessage {
  id        String           @id @default(cuid())
  projectId String?
  name      String
  email     String
  subject   String
  message   String           @db.Text
  locale    Locale
  status    SubmissionStatus @default(NEW)
  createdAt DateTime         @default(now())
  project   Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([projectId])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
